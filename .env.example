# Optional server port. Defaults to 3000.
PORT=3000

# Optional AI provider API keys. You can also paste a key into the UI for a one-off suggestion.
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# Optional model overrides.
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
GOOGLE_MODEL=gemini-2.0-flash
